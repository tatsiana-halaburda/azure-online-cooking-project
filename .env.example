# Copy to .env (do not commit). README → Environment table. Mac: unixodbc + msodbcsql18 for pyodbc; run sql/01…05 before APIs.

DB_USERNAME=
DB_PASSWORD=
DB_SERVER=tcp:YOURSERVER.database.windows.net
DB_DATABASE=YOURDB

# Ordering → Inventory (local). docker compose overrides ordering to http://inventory:8001
INVENTORY_SERVICE_URL=http://localhost:8001

# Optional: overrides DB_* when set
# AZURE_SQL_CONNECTION_STRING=
# DB_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Practice 3 — Service Bus: full SAS connection strings (one line; quotes optional). Same AZURE_SERVICEBUS_QUEUE_NAME in both apps.
AZURE_SERVICEBUS_SEND_CONNECTION_STRING=
AZURE_SERVICEBUS_LISTEN_CONNECTION_STRING=
AZURE_SERVICEBUS_QUEUE_NAME=
# AZURE_SERVICEBUS_POLL_INTERVAL_SECONDS=5
