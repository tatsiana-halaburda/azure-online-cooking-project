# Copy to .env (don't commit secrets). Use repo .venv: `source .venv/bin/activate` then `uvicorn …`
# Mac: `brew install unixodbc` if pyodbc can't load libodbc; `brew install sqlcmd` to run sql/ scripts from CLI
# Driver missing: tap microsoft/mssql-release, then ACCEPT_EULA=Y brew install msodbcsql18
# DB empty? Run sql/01 … 05 in order (ADS or sqlcmd). Sample order id: 33333333-3333-3333-3333-333333333333

DB_USERNAME=
DB_PASSWORD=
DB_SERVER=tcp:YOURSERVER.database.windows.net
DB_DATABASE=YOURDB

INVENTORY_SERVICE_URL=http://localhost:8001
# docker compose overrides this for ordering → use http://inventory:8001 inside the stack
# Docker: start Docker Desktop, repo root: `docker compose up --build -d` (needs `.env` with DB_* set)

# Optional — if set, ignores DB_* above
# AZURE_SQL_CONNECTION_STRING=
